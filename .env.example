# Prisma
DATABASE_URL=

# App URL (no trailing slash). Used in MercadoPago back_url, OG images, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=

# UploadThing
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Mapbox
# Public URL-restricted token for client-side Search Box suggestions.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Server-only token for Search Box retrieve requests.
MAPBOX_SECRET_TOKEN=

# MercadoPago
# Access token from https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=
# Webhook signing secret. Set after configuring the webhook URL in the MP
# panel (Webhooks > Configurar notificaciones, "Planes y Suscripciones"
# events). When unset, webhook signature verification is skipped and a
# warning is logged — convenient for local dev, do not deploy without it.
MP_WEBHOOK_SECRET=

# Local webhook testing:
#   1. Run `pnpm dev`
#   2. Tunnel port 3000 (e.g. `ngrok http 3000` or `cloudflared tunnel`)
#   3. In MP panel point the webhook to <tunnel>/api/mercadopago
#   4. Use a MP test buyer account to subscribe
#   See https://www.mercadopago.com.ar/developers/es/docs/subscriptions

# OpenAI (for AI menu import feature)
OPENAI_API_KEY=
